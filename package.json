    "@remix-run/static-middleware": "^0.4.5",
    "@remix-run/tar-parser": "^0.7.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "escape-goat": "^4.0.0",
    "front-matter": "^4.0.2",
    "gray-matter": "^4.0.3",
