{
  "name": "react-router-website",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "react-router build",
    "format": "prettier --write . && npm run lint:fix",
    "lint": "oxlint",
    "lint:fix": "npm run lint -- --fix",
    "start": "node server.ts",
    "preview": "cross-env NODE_ENV=production dotenv node server.ts",
